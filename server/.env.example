# ── Polaris backend + agent runtime ─────────────────────────────────────────
# Arc Testnet (verified values)
ARC_RPC_URL=https://rpc.testnet.arc.network

# Agent intelligence — OpenRouter (OpenAI-compatible). Powers both scoring
# (the trust core) and the agents' work generation.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions

# Verifier signer — the key whose ADDRESS was passed to VerifierBridge at deploy
# (VERIFIER_SIGNER_ADDRESS). The backend signs verdicts with this; keep it secret.
VERIFIER_SIGNER_KEY=0x...

# Deployed contract addresses (from the Hardhat deploy script output)
VITE_USDC_ADDRESS=0x3600000000000000000000000000000000000000
VITE_CONTRACT_USDC_ESCROW=0x...
VITE_CONTRACT_AGENT_REGISTRY=0x...
VITE_CONTRACT_BID_ENGINE=0x...
VITE_CONTRACT_TASK_REGISTRY=0x...
VITE_CONTRACT_VERIFIER_BRIDGE=0x...

PORT=8787
DELIVERABLE_STORE=./deliverables.json
INDEX_LOOKBACK_BLOCKS=500000

# ── Autonomous swarm (node agent.js) ─────────────────────────────────────────
SWARM_POLL_MS=12000
# One funded Arc wallet per agent. markup<1 undercuts the budget (lower bid wins).
AGENTS_JSON=[{"name":"Atlas-Research","key":"0x...","capabilities":["research","analysis","summarization"],"stake":5,"markup":0.85},{"name":"Scribe-Writer","key":"0x...","capabilities":["writing","translation"],"stake":5,"markup":0.9}]

# ── x402 / Gateway nanopayments (Circle) ─────────────────────────────────────
X402_FACILITATOR=https://gateway-api-testnet.circle.com
X402_NETWORK=eip155:5042002
X402_CHAIN=arcTestnet
X402_SELLER=                 # defaults to the verifier signer address if set
X402_PAY_FOR_ORACLE=0        # set 1 to have agents pay $0.01 for the oracle sub-service
X402_ORACLE_URL=http://localhost:8787/api/oracle/price
